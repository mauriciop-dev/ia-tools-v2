---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Seguimiento y análisis inteligente de novedades en IA (Google, X, YouTube)" } = Astro.props;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title} | IA Tools 2.0</title>
    <meta name="title" content={`${title} | IA Tools 2.0`} />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | IA Tools 2.0`} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={`${title} | IA Tools 2.0`} />
    <meta property="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>
  <body>
    <div class="stars-bg"></div>
    <main class="animate-fade">
      <slot />
    </main>
    <style>
      .stars-bg {
        position: fixed;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        z-index: -1;
        background-image: 
          radial-gradient(1px 1px at 20px 30px, var(--text-muted), transparent),
          radial-gradient(1.5px 1.5px at 100px 150px, var(--neon-teal), transparent),
          radial-gradient(1px 1px at 300px 80px, var(--hyper-violet), transparent);
        background-size: 400px 400px;
        opacity: 0.2;
      }
      
      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }
    </style>
  </body>
</html>
